// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/lib/server/prisma"
}

datasource db {
  provider = "sqlite"
}

model Profile {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  email     String   @unique
  username  String
  bio       String?
  xp        Float    @default(0)

  @@index([email])
  @@index([xp])
}
